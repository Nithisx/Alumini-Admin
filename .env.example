# Production/staging API base (used when not running Vite in DEV mode)
VITE_API_BASE_URL=https://api.karpagamalumni.in/api/v1

# Dev API base path used by src/config/api.js (proxied by Vite)
VITE_DEV_API_BASE_URL=/api/v1

# Vite dev proxy target origin
VITE_API_PROXY_TARGET=https://api.karpagamalumni.in
